# FlowBoard – Environment Variables Template
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git!

# Groq API key for AI Chat feature
# Get it at: https://console.groq.com → API Keys
GROQ_API_KEY="your_groq_api_key_here"

# Pinecone API key for AI vector memory
# Get it at: https://app.pinecone.io → API Keys
PINECONE_API_KEY="your_pinecone_api_key_here"

# Supabase JWT Secret for authentication
# Get it at: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET="your_supabase_jwt_secret_here"
